{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "target": "es2024",
    "lib": ["es2024", "dom", "dom.iterable"],
    "noEmit": true,
    "esModuleInterop": true,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": true,
    "module": "esnext",
    "moduleResolution": "bundler"
  },
  "exclude": ["node_modules"],
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "references": [
    {
      "path": "../../config"
    },
    {
      "path": "../../graphql"
    },
    {
      "path": "../../common"
    },
    {
      "path": "../../components"
    }
  ]
}
